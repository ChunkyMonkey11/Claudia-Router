{
  "name": "claudia-router",
  "version": "0.1.0",
  "description": "A lightweight Anthropic-compatible local router for sending Claude-style coding requests to OpenAI-compatible model backends.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudia-claude": "scripts/claudia-claude.mjs"
  },
  "files": [
    ".env.example",
    "LICENSE",
    "README.md",
    "config.example.json",
    "dist",
    "scripts",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChunkyMonkey11/Claudia-Router.git"
  },
  "bugs": {
    "url": "https://github.com/ChunkyMonkey11/Claudia-Router/issues"
  },
  "homepage": "https://github.com/ChunkyMonkey11/Claudia-Router#readme",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "serve": "node dist/index.js",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run typecheck && npm test",
    "claude:fast": "node scripts/claudia-claude.mjs --model claude-3-5-sonnet-latest",
    "claude:glm": "node scripts/claudia-claude.mjs --model claude-3-5-sonnet-glm",
    "claude:smoke": "node scripts/claudia-claude.mjs --model claude-3-haiku-latest"
  },
  "keywords": [
    "anthropic",
    "claude",
    "openai",
    "nvidia",
    "router",
    "proxy"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
